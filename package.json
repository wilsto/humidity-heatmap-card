{
  "name": "humidity-heatmap-card",
  "version": "1.0.0",
  "type": "module",
  "description": "Home Assistant Lovelace card — multi-room humidity heatmap with adaptive thresholds",
  "main": "dist/humidity-heatmap-card.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "hacs",
    "humidity",
    "heatmap",
    "custom-card"
  ],
  "author": "Will",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wilsto/humidity-heatmap-card.git"
  },
  "homepage": "https://github.com/wilsto/humidity-heatmap-card",
  "bugs": {
    "url": "https://github.com/wilsto/humidity-heatmap-card/issues"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-replace": "^6.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "rollup": "^4.0.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.5.0",
    "vitest": "^3.0.0",
    "jsdom": "^26.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "dependencies": {
    "lit": "^3.0.0"
  }
}
